{
  "name": "@portosaur/core",
  "version": "0.20.0",
  "description": "The engine of portosaur that translates YAML configuration into Docusaurus structures.",
  "license": "GPL-3.0-only",
  "author": "soymadip",
  "homepage": "https://soymadip.github.io/portosaur",
  "repository": {
    "type": "git",
    "url": "https://github.com/soymadip/portosaur"
  },
  "files": [
    "src",
    "configSchema.json"
  ],
  "scripts": {
    "prepack": "bun ../cli/bin/porto.mjs schema"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.mjs",
      "default": "./src/index.mjs"
    },
    "./constants": {
      "types": "./src/constants.d.ts",
      "import": "./src/constants.mjs",
      "default": "./src/constants.mjs"
    }
  },
  "types": "./src/index.d.ts",
  "dependencies": {
    "@portosaur/logger": "workspace:*",
    "js-yaml": "^4.1.1",
    "prism-react-renderer": "^2.4.1",
    "rehype-katex": "7",
    "remark-math": "6",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
