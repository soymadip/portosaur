    "chalk": "^5.6.2",
    "clsx": "^2.1.1",
    "favicons": "^7.2.0",
    "framer-motion": "^12.38.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-pdf": "^10.4.1",
    "react-rnd": "^10.5.3",
    "react-slick": "^0.31.0",
    "slick-carousel": "^1.8.1"
