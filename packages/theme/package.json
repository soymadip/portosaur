{
  "name": "@portosaur/theme",
  "version": "0.21.2",
  "description": "Theme components for Portosaur - React components, static assets etc.",
  "license": "GPL-3.0-only",
  "author": "soymadip",
  "homepage": "https://soymadip.github.io/portosaur",
  "repository": {
    "type": "git",
