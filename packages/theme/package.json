    "./assets/*": "./assets/*",
    "./plugins/*": "./plugins/*",
    "./theme/*": "./theme/*",
    "./components/*": "./components/*"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/plugin-pwa": "^3.10.1",
    "@docusaurus/preset-classic": "^3.10.1",
    "@easyops-cn/docusaurus-search-local": "^0.55.2",
    "@embedpdf/react-pdf-viewer": "^2.14.4",
    "@embedpdf/snippet": "^2.14.4",
    "@fontsource-variable/geologica": "^5.2.8",
    "@fontsource-variable/lexend": "^5.2.11",
    "@fontsource/alata": "^5.2.8",
    "@iconify-json/devicon": "^1.2.62",
    "@iconify-json/fa7-solid": "^1.2.5",
    "@iconify-json/line-md": "^1.2.16",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/lucide": "^1.2.116",
    "@iconify-json/mdi": "^1.2.3",
    "@iconify-json/octicon": "^1.2.29",
