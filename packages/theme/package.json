    "@iconify-json/streamline-sharp": "^1.2.0",
    "@iconify/react": "^6.0.2",
    "@iconify/utils": "^3.1.4",
    "@portosaur/core": "workspace:*",
    "chalk": "^5.6.2",
    "clsx": "^2.1.1",
    "katex": "^0.17.0",
    "prism-react-renderer": "^2.4.1",
    "react-rnd": "^10.5.3"
  },
  "devDependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
