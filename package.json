{
  "name": "portosaurus",
  "version": "0.15.1",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "clear && bun install && bun x docusaurus start && bun x docusaurus clear",
    "build": "bun install && bun x docusaurus build",
    "serve": "bun install && bun x docusaurus serve",
    "deploy": "bun x docusaurus deploy",
    "clear": "bun x docusaurus clear",
    "swizzle": "bun x docusaurus swizzle",
    "write-translations": "bun x docusaurus write-translations",
    "write-heading-ids": "bun x docusaurus write-heading-ids"
  },
  "dependencies": {
    "@docusaurus/core": "^3.10.0",
    "@docusaurus/preset-classic": "^3.10.0",
    "@easyops-cn/docusaurus-search-local": "^0.52.1",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.1.1",
    "favicons": "7.2.0",
    "framer-motion": "^12.38.0",
    "plugin-image-zoom": "github:flexanalytics/plugin-image-zoom",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^5.5.0",
    "react-pdf": "^10.4.1",
    "react-rnd": "^10.5.3",
    "react-slick": "^0.31.0",
    "sharp": "^0.34.4",
    "slick-carousel": "^1.8.1"
  },
  "overrides": {
    "webpack": "5.105.4"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "^3.10.0",
    "@docusaurus/types": "^3.10.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
