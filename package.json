{
  "name": "portosaur",
  "description": "Complete portfolio cum personal website solution for your digital personality.",
  "version": "0.15.1",
  "license": "GPL-3.0-only",
  "private": true,
  "homepage": "https://soymadip.github.io/portosaur",
  "repository": {
    "type": "git",
    "url": "https://github.com/soymadip/portosaur"
  },
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "schema": "bun packages/cli/bin/porto.mjs schema",
    "playground": "bun src/playground.mjs",
    "build": "bun run playground build",
    "dev": "bun run playground dev",
    "dev:docs": "bun run --cwd docs dev",
    "test:all": "bun run schema && bun test",
    "test:smoke": "bun run src/smoke-test.mjs"
  },
  "devDependencies": {
    "prettier": "latest"
  },
  "engines": {
    "node": ">=24.15.0"
  }
}
