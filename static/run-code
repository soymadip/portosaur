#!/bin/env bash


#------------------ Command Dictionary ------------------------
declare -A EXT_MAP

EXT_MAP=(
    ["py"]="python3 \$FILE"
    ["js"]="node \$FILE"
    ["ts"]="ts-node \$FILE"
    ["lua"]="lua \$FILE"
    ["rb"]="ruby \$FILE"
    ["go"]="go run \$FILE"
    ["rs"]="rustc \$FILE -o /tmp/run_out && /tmp/run_out"
    ["c"]="gcc \$FILE -o /tmp/run_out && /tmp/run_out"

    # Shell Script
    ["sh"]="bash \$FILE"
    ["bash"]="bash \$FILE"
    ["zsh"]="zsh \$FILE"

    # C++
    ["cpp"]="g++ \$FILE -o /tmp/run_out && /tmp/run_out"
    ["cxx"]="g++ \$FILE -o /tmp/run_out && /tmp/run_out"
    ["c++"]="g++ \$FILE -o /tmp/run_out && /tmp/run_out"
)

#---------------------------------------------------------

# Function to display help
usage() {
    echo "Usage: run-code <filename> [-c <command>] [-h]"
    echo ""
    echo "Options:"
    echo "  -c <command>  Force a specific command/interpreter to run the file."
    echo "  -h            Show this help message."
    exit 0
}

# 1. Initial check
if [[ -z "$1" ]] || [[ "$1" == "-h" ]]; then
    usage
fi

FILE="$1"
shift # Remove filename from arguments to parse flags

# Parse Options
CUSTOM_CMD=""
while getopts "c:h" opt; do
    case ${opt} in
        c ) CUSTOM_CMD=$OPTARG ;;
        h ) usage ;;
        \? ) usage ;;
    esac
done

# Validation
if [[ ! -f "$FILE" ]]; then
    echo "Error: File '$FILE' not found."
    exit 1
fi


# clear
echo -e "\n\n"

# Custom Command Override (-c)
if [[ -n "$CUSTOM_CMD" ]]; then
    echo ":: Using custom command: $CUSTOM_CMD"
    $CUSTOM_CMD "$FILE"
    exit $?
fi


# Shebang Detection
# Read first 2 bytes to check for #!
SHEBANG=$(head -c 2 "$FILE" 2>/dev/null)

if [[ "$SHEBANG" == "#!" ]]; then
    echo ":: Executing via shebang..."
    chmod +x "$FILE"
    exec ./"$FILE"
fi


EXT="${FILE##*.}"

# Execution Logic
if [[ -n "${EXT_MAP[$EXT]}" ]]; then
    COMMAND_TEMPLATE="${EXT_MAP[$EXT]}"

    eval "${COMMAND_TEMPLATE//\$FILE/$FILE}"
else
    echo "Error: No shebang found and extension '.$EXT' is unsupported."
    echo "Try using: run-code $FILE -c <command>"
    exit 1
fi
